{
  "manifest_version": 3,
  "name": "TouchGuide — Web Element Assistant",
  "version": "2.0.0",
  "description": "Click any element to get a contextual, site-specific explanation of what it does. Powered by Claude AI.",

  "permissions": [
    "activeTab",
    "storage",
    "tts"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "src/background/service-worker.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "src/utils/element-info.js",
        "src/ai/icon-recognizer.js",
        "src/ai/context-analyzer.js",
        "src/ai/context-ai.js",
        "src/content/overlay.js",
        "src/content/content-script.js"
      ],
      "css": ["styles/guidance-card.css"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "TouchGuide"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": ["styles/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
